---
export interface Props {
  title: string
}

const {title} = Astro.props;
---

<section class="layout-widget">
  <h3 class="layout-widget__title">{title}</h3>
  <div class="layout-widget__content">
    <slot/>
  </div>
</section>

<style lang="scss">
  .layout-widget {

    &__title {
      margin-bottom: 1.25rem;
      text-transform: uppercase;
      color: rgb(125, 125, 125);
    }

    &__content {
      font-size: 0.875rem;
      line-height: 1.5;
      font-style: italic;
      color: rgb(164, 164, 164);
    }
  }
</style>